# HYPERPLM — Environment Variables
# Copy to .env and fill in your values

# ── Environment ─────────────────────────────────────────────────────────────
# "development" (default) or "production".
# In production the app REFUSES TO START if SECRET_KEY is missing/default,
# and it will NOT seed any default admin account.
ENVIRONMENT=development

# ── Auth mode ───────────────────────────────────────────────────────────────
# "local"  → username/password login (for self-hosted installs)
# "google" → Google OAuth (for VPS at 3dprintdudes.io)
AUTH_MODE=local

# JWT secret key — REQUIRED in production, must be >=32 chars.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# ── First admin (bootstrap) ─────────────────────────────────────────────────
# The very first admin account is created from these on an empty database and
# is forced to change its password on first login. In production, if these are
# unset, NO admin is created (provision one explicitly — no default creds ship).
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Minimum length for new/changed passwords.
PASSWORD_MIN_LENGTH=8

# ── Google OAuth (only needed when AUTH_MODE=google) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_BASE_URL=https://3dprintdudes.io/plm

# Optional: comma-separated email whitelist. Empty = allow any Google account.
# ALLOWED_EMAILS=you@example.com,teammate@example.com

# ── Storage paths ────────────────────────────────────────────────────────────
# For Docker: leave as-is (mapped to Docker volumes)
# For bare uvicorn: set to local paths
FILES_ROOT=/srv/plm/files
DB_PATH=/srv/plm/plm.db

# ── File versioning ──────────────────────────────────────────────────────────
MAX_FILE_VERSIONS=3

# CAD file extensions that get versioned (comma-separated, with dot)
CAD_EXTENSIONS=.prt,.asm,.drw,.stl,.3mf,.obj,.step,.stp,.sldprt,.sldasm,.ipt,.iam

# ── Open-in-place (Windows LAN only) ─────────────────────────────────────────
# UNC path to the same directory that FILES_ROOT points to inside Docker.
# Windows clients need read access to this share to open files directly.
# Example: FILES_ROOT=/srv/plm/files → FILES_UNC_ROOT=\\192.168.1.37\plm-files
# Leave blank to disable the "Open" button (download-only mode).
# FILES_UNC_ROOT=\\192.168.1.37\plm-files

# If workstations map the share to a drive letter, set it here (e.g. Z:)
# Drive letters are more reliable than UNC paths with some NX installations.
# FILES_MAPPED_DRIVE=Z:
